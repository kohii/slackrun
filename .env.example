# Slack credentials — both required.
SLACK_BOT_TOKEN=xoxb-...
SLACK_APP_TOKEN=xapp-...

# Optional knobs.
# MAX_CONCURRENT=5
# MIN_EVENT_AGE_MS_AT_BOOT=300000
# BACKFILL_INTERVAL_MS=60000           # 0 disables. Polls conversations.history per type:message channel as a Socket Mode backstop.
# BACKFILL_LOOKBACK_MS=600000          # First-poll window when no live event has been seen yet on that channel.
# LOG_LEVEL=info                       # debug | info | warn | error
# ALLOW_RAW_EVENT_TEXT_LOG=false       # debug only — bypasses event-text scrubbing
# SLACKRUN_CONFIG_PATH=~/.config/slackrun/rules.yaml
